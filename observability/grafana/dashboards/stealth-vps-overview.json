{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "stealth-vps overview — protocol-side metrics (Reality inbound, Hysteria2 traffic + online clients) sourced from the node_exporter textfile written by stealth-vps-metrics-update.py. Pair with Grafana dashboard 1860 (Node Exporter Full) for host-side metrics.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "title": "Health",
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Panel scrape error",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "stealth_vps_panel_scrape_error{instance=~\"$host\"}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "OK", "color": "green"}, "1": {"text": "ERROR", "color": "red"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Hysteria2 scrape error",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "stealth_vps_hysteria_scrape_error{instance=~\"$host\"}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "OK", "color": "green"}, "1": {"text": "ERROR", "color": "red"}}}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Hysteria2 online clients",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "stealth_vps_hysteria_online_clients{instance=~\"$host\"}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Last scrape (relative)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "time() - stealth_vps_last_scrape_timestamp{instance=~\"$host\"}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 120}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "type": "row",
      "id": 200,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "title": "Reality (VLESS) — inbound traffic",
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Upload bytes/s per inbound",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rate(stealth_vps_inbound_up_bytes{instance=~\"$host\"}[5m])",
          "legendFormat": "{{remark}} ({{protocol}}:{{port}})",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "Download bytes/s per inbound",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rate(stealth_vps_inbound_down_bytes{instance=~\"$host\"}[5m])",
          "legendFormat": "{{remark}} ({{protocol}}:{{port}})",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "Per-client upload (top 10)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "topk(10, rate(stealth_vps_client_up_bytes{instance=~\"$host\"}[5m]))",
          "legendFormat": "{{client_email}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "Per-client download (top 10)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "topk(10, rate(stealth_vps_client_down_bytes{instance=~\"$host\"}[5m]))",
          "legendFormat": "{{client_email}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "row",
      "id": 300,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "title": "Hysteria2 — per-client traffic",
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Tx (server -> client) bytes/s, top 10",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "topk(10, rate(stealth_vps_hysteria_tx_bytes{instance=~\"$host\"}[5m]))",
          "legendFormat": "{{client_id}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "Rx (client -> server) bytes/s, top 10",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "topk(10, rate(stealth_vps_hysteria_rx_bytes{instance=~\"$host\"}[5m]))",
          "legendFormat": "{{client_id}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["stealth-vps", "anti-censorship", "xray", "hysteria2"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": {"qryType": 1, "query": "label_values(stealth_vps_last_scrape_timestamp, instance)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "regex": "",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "stealth-vps overview",
  "uid": "stealth-vps-overview",
  "version": 1,
  "weekStart": ""
}
