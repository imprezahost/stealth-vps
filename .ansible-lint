---
# ansible-lint config for stealth-vps.

# Galaxy collections live under ansible/collections/ when installed locally
# (collections_path in ansible.cfg). They're third-party code — don't lint.
exclude_paths:
  - ansible/collections/
  - .cache/
  - .ansible/

# Profile bumped to "production" in v0.6.1 cleanup — we cleared every
# basic-profile failure (see CHANGELOG) and the next lint run reported
# "Passed: 0 failure(s), 0 warning(s) ... 'production' profile passed",
# so we just lift the floor to match what the code already satisfies.
# Production adds rules for: name[missing], yaml[trailing-spaces],
# yaml[indentation], yaml[hyphens], yaml[empty-lines], schema[meta], etc.
profile: production
