---
# ansible-lint config for stealth-vps.

# Galaxy collections live under ansible/collections/ when installed locally
# (collections_path in ansible.cfg). They're third-party code — don't lint.
exclude_paths:
  - ansible/collections/
  - .cache/
  - .ansible/

# Profile bumped to "safety" in the v0.6.1 cleanup sweep. The next
# rung up, "production", flags every task that mutates state outside
# a handler — including our daemon-reload / ufw-reload tasks that
# intentionally run unconditionally to recover from drift. That's an
# architectural opinion we don't share; skip_list disables `no-handler`
# instead of redesigning the role around handlers.
profile: safety
skip_list:
  # The role uses direct tasks (not handlers) for systemd daemon-reload
  # + UFW reload because those are idempotent and the explicit ordering
  # matters more than handler-batching efficiency. ansible-lint's
  # production profile insists on handlers; we opt out per-task with
  # an honest skip_list entry rather than restructuring the role.
  - no-handler
