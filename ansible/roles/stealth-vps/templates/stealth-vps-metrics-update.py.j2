#!/usr/bin/env python3
# {{ ansible_managed }}
# Edit ansible/roles/stealth-vps/templates/stealth-vps-metrics-update.py.j2 —
# local edits are overwritten on the next playbook run.
"""stealth-vps metrics updater.

Pulls traffic counters from:
  - the 3X-UI panel REST API (per-inbound and per-client up/down bytes
    for the Reality VLESS inbound — Xray's bundled stats subsystem
    surfaced through the panel)
  - the apernet/hysteria2 trafficStats HTTP API (per-client tx/rx
    plus the online-clients list — JSON, since 2.8.2 doesn't expose
    a /metrics endpoint natively)

Writes the combined output as a Prometheus textfile that
prometheus-node-exporter picks up via --collector.textfile.directory.
That way Prometheus has ONE scrape target (:9100) covering the host
and both protocol stacks.

Exits 0 even when one source is unreachable — we still want the other
half of the data, plus a `_scrape_error` gauge that flips to 1 so
dashboards can warn.
"""

# --- Ansible-templated paths (kept outside the raw block below so they interpolate)
PANEL_STATE = "/etc/stealth-vps/panel.state.yml"
HYSTERIA_TRAFFIC_URL = "http://{{ stealth_vps_hysteria_traffic_stats_listen }}"
OUTPUT_DIR = "{{ stealth_vps_metrics_textfile_dir }}"
TLS_FULLCHAIN = "{{ stealth_vps_tls_dir }}/fullchain.pem"

{% raw %}
import json
import os
import re
import ssl
import subprocess
import sys
import tempfile
import time
import traceback
import urllib.parse
import urllib.request

from datetime import datetime, timezone

import yaml  # python3-yaml ships with Debian 12

OUTPUT_FILE = os.path.join(OUTPUT_DIR, "stealth-vps.prom")
LBRACE = "{"
RBRACE = "}"


def quote(value):
    """Prometheus label-value escape."""
    return str(value).replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")


def metric_line(name, labels_str, value):
    """Build a single Prometheus line, dodging the {%...%} Jinja trap by
    keeping the brace characters out of any format string literal."""
    return name + LBRACE + labels_str + RBRACE + " " + str(value)


def load_yaml(path):
    with open(path) as f:
        return yaml.safe_load(f)


def fetch_panel_inbounds():
    """Returns (inbounds_list, error_string_or_None)."""
    try:
        panel = load_yaml(PANEL_STATE)
        base = "https://127.0.0.1:" + str(int(panel["port"])) + "/" + panel["web_base_path"]
        ctx = ssl.create_default_context()
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        # 1. Login
        body = urllib.parse.urlencode({
            "username": panel["username"],
            "password": panel["password"],
        }).encode()
        req = urllib.request.Request(base + "/login", data=body)
        with urllib.request.urlopen(req, context=ctx, timeout=10) as r:
            cookie = r.headers.get("Set-Cookie", "")
        if not cookie:
            return [], "no Set-Cookie from /login"
        cookie = cookie.split(";", 1)[0]
        # 2. inbounds/list
        req = urllib.request.Request(
            base + "/panel/api/inbounds/list",
            headers={"Cookie": cookie},
        )
        with urllib.request.urlopen(req, context=ctx, timeout=10) as r:
            payload = json.load(r)
        if not payload.get("success"):
            return [], "panel list returned success=false"
        return payload.get("obj") or [], None
    except Exception as e:
        return [], type(e).__name__ + ": " + str(e)


def fetch_hysteria_traffic():
    """Returns ((traffic_dict, online_count), error_string_or_None)."""
    try:
        req = urllib.request.Request(HYSTERIA_TRAFFIC_URL + "/traffic")
        with urllib.request.urlopen(req, timeout=5) as r:
            traffic = json.load(r)
        req = urllib.request.Request(HYSTERIA_TRAFFIC_URL + "/online")
        with urllib.request.urlopen(req, timeout=5) as r:
            online = json.load(r)
        if not isinstance(traffic, dict):
            traffic = {}
        if isinstance(online, list):
            count = len(online)
        elif isinstance(online, dict):
            count = sum(int(v) for v in online.values())
        else:
            count = 0
        return (traffic, count), None
    except Exception as e:
        return ({}, 0), type(e).__name__ + ": " + str(e)


def fetch_cert_expiry():
    """Returns (seconds_until_expiry_or_None, error_string_or_None).

    Reads /etc/stealth-vps/tls/fullchain.pem via openssl. None when no
    Let's Encrypt cert is configured (which is fine — just emit the
    metric as a missing/-1 indicator and let the alert ignore it)."""
    if not os.path.isfile(TLS_FULLCHAIN):
        return None, None  # no cert configured; not an error
    try:
        out = subprocess.check_output(
            ["openssl", "x509", "-in", TLS_FULLCHAIN, "-noout", "-enddate"],
            stderr=subprocess.STDOUT,
            timeout=5,
        ).decode().strip()
        # Format: notAfter=Aug 11 16:49:54 2026 GMT
        m = re.match(r"^notAfter=(.+)$", out)
        if not m:
            return None, "unexpected openssl output: " + out
        # Parse the date — locale-independent, %b is English month abbrev.
        not_after = datetime.strptime(
            m.group(1), "%b %d %H:%M:%S %Y %Z"
        ).replace(tzinfo=timezone.utc)
        seconds = int((not_after - datetime.now(timezone.utc)).total_seconds())
        return seconds, None
    except Exception as e:
        return None, type(e).__name__ + ": " + str(e)


def fetch_fail2ban_stats():
    """Returns (per_jail_dict, error_string_or_None).

    Each value is {currently: int, total: int, failed: int}.
    """
    try:
        # Which jails are running?
        out = subprocess.check_output(
            ["fail2ban-client", "status"],
            stderr=subprocess.STDOUT,
            timeout=5,
        ).decode()
        m = re.search(r"Jail list:\s*(.+)", out)
        if not m:
            return {}, "no Jail list in fail2ban-client status output"
        jails = [j.strip() for j in m.group(1).split(",") if j.strip()]
        per_jail = {}
        for jail in jails:
            jout = subprocess.check_output(
                ["fail2ban-client", "status", jail],
                stderr=subprocess.STDOUT,
                timeout=5,
            ).decode()
            curr = re.search(r"Currently banned:\s+(\d+)", jout)
            tot = re.search(r"Total banned:\s+(\d+)", jout)
            fail_c = re.search(r"Currently failed:\s+(\d+)", jout)
            fail_t = re.search(r"Total failed:\s+(\d+)", jout)
            per_jail[jail] = {
                "currently_banned": int(curr.group(1)) if curr else 0,
                "total_banned": int(tot.group(1)) if tot else 0,
                "currently_failed": int(fail_c.group(1)) if fail_c else 0,
                "total_failed": int(fail_t.group(1)) if fail_t else 0,
            }
        return per_jail, None
    except FileNotFoundError:
        return {}, None  # fail2ban not installed; not an error
    except Exception as e:
        return {}, type(e).__name__ + ": " + str(e)


def build_inbound_labels(ib):
    return (
        'inbound_id="' + quote(ib.get("id")) + '",'
        'remark="' + quote(ib.get("remark", "")) + '",'
        'protocol="' + quote(ib.get("protocol", "")) + '",'
        'port="' + quote(ib.get("port", "")) + '"'
    )


def build_lines(panel_inbounds, panel_err, hy_traffic, hy_online, hy_err,
                cert_seconds, cert_err, f2b_stats, f2b_err):
    lines = []
    now = int(time.time())

    lines.append("# HELP stealth_vps_last_scrape_timestamp Unix time of the last scrape attempt.")
    lines.append("# TYPE stealth_vps_last_scrape_timestamp gauge")
    lines.append("stealth_vps_last_scrape_timestamp " + str(now))

    lines.append("# HELP stealth_vps_panel_scrape_error 1 when the 3X-UI panel API was unreachable.")
    lines.append("# TYPE stealth_vps_panel_scrape_error gauge")
    lines.append("stealth_vps_panel_scrape_error " + ("1" if panel_err else "0"))

    lines.append("# HELP stealth_vps_hysteria_scrape_error 1 when the Hysteria2 trafficStats API was unreachable.")
    lines.append("# TYPE stealth_vps_hysteria_scrape_error gauge")
    lines.append("stealth_vps_hysteria_scrape_error " + ("1" if hy_err else "0"))

    lines.append("# HELP stealth_vps_cert_scrape_error 1 when the TLS cert metadata could not be read.")
    lines.append("# TYPE stealth_vps_cert_scrape_error gauge")
    lines.append("stealth_vps_cert_scrape_error " + ("1" if cert_err else "0"))

    lines.append("# HELP stealth_vps_fail2ban_scrape_error 1 when fail2ban-client could not be queried.")
    lines.append("# TYPE stealth_vps_fail2ban_scrape_error gauge")
    lines.append("stealth_vps_fail2ban_scrape_error " + ("1" if f2b_err else "0"))

    if panel_inbounds:
        lines.append("# HELP stealth_vps_inbound_up_bytes Total upload bytes per inbound.")
        lines.append("# TYPE stealth_vps_inbound_up_bytes counter")
        lines.append("# HELP stealth_vps_inbound_down_bytes Total download bytes per inbound.")
        lines.append("# TYPE stealth_vps_inbound_down_bytes counter")
        lines.append("# HELP stealth_vps_inbound_enabled 1 if the inbound is enabled, 0 otherwise.")
        lines.append("# TYPE stealth_vps_inbound_enabled gauge")
        lines.append("# HELP stealth_vps_client_up_bytes Per-client upload bytes inside an inbound.")
        lines.append("# TYPE stealth_vps_client_up_bytes counter")
        lines.append("# HELP stealth_vps_client_down_bytes Per-client download bytes inside an inbound.")
        lines.append("# TYPE stealth_vps_client_down_bytes counter")
        for ib in panel_inbounds:
            lbl = build_inbound_labels(ib)
            lines.append(metric_line("stealth_vps_inbound_up_bytes", lbl, int(ib.get("up", 0))))
            lines.append(metric_line("stealth_vps_inbound_down_bytes", lbl, int(ib.get("down", 0))))
            lines.append(metric_line("stealth_vps_inbound_enabled", lbl, 1 if ib.get("enable") else 0))
            for cs in ib.get("clientStats") or []:
                clbl = lbl + ',client_email="' + quote(cs.get("email", "")) + '"'
                lines.append(metric_line("stealth_vps_client_up_bytes", clbl, int(cs.get("up", 0))))
                lines.append(metric_line("stealth_vps_client_down_bytes", clbl, int(cs.get("down", 0))))

    lines.append("# HELP stealth_vps_hysteria_online_clients Number of clients currently connected to Hysteria2.")
    lines.append("# TYPE stealth_vps_hysteria_online_clients gauge")
    lines.append("stealth_vps_hysteria_online_clients " + str(int(hy_online)))

    if hy_traffic:
        lines.append("# HELP stealth_vps_hysteria_tx_bytes Hysteria2 per-client transmit bytes (server -> client).")
        lines.append("# TYPE stealth_vps_hysteria_tx_bytes counter")
        lines.append("# HELP stealth_vps_hysteria_rx_bytes Hysteria2 per-client receive bytes (client -> server).")
        lines.append("# TYPE stealth_vps_hysteria_rx_bytes counter")
        for client_id, stats in hy_traffic.items():
            if not isinstance(stats, dict):
                continue
            lbl = 'client_id="' + quote(client_id) + '"'
            lines.append(metric_line("stealth_vps_hysteria_tx_bytes", lbl, int(stats.get("tx", 0))))
            lines.append(metric_line("stealth_vps_hysteria_rx_bytes", lbl, int(stats.get("rx", 0))))

    # TLS cert expiry (-1 means "no cert configured" so alerts can ignore)
    lines.append("# HELP stealth_vps_cert_expiry_seconds Seconds until the configured TLS cert expires (-1 if no cert).")
    lines.append("# TYPE stealth_vps_cert_expiry_seconds gauge")
    if cert_seconds is None:
        lines.append('stealth_vps_cert_expiry_seconds{cert="le-fullchain"} -1')
    else:
        lines.append('stealth_vps_cert_expiry_seconds{cert="le-fullchain"} ' + str(int(cert_seconds)))

    # fail2ban per-jail counters
    if f2b_stats:
        lines.append("# HELP stealth_vps_fail2ban_currently_banned IPs currently in the jail's banlist.")
        lines.append("# TYPE stealth_vps_fail2ban_currently_banned gauge")
        lines.append("# HELP stealth_vps_fail2ban_total_banned Total bans the jail has issued since fail2ban started.")
        lines.append("# TYPE stealth_vps_fail2ban_total_banned counter")
        lines.append("# HELP stealth_vps_fail2ban_currently_failed Auth failures in the jail's current window.")
        lines.append("# TYPE stealth_vps_fail2ban_currently_failed gauge")
        lines.append("# HELP stealth_vps_fail2ban_total_failed Total auth failures the jail has seen since fail2ban started.")
        lines.append("# TYPE stealth_vps_fail2ban_total_failed counter")
        for jail, s in f2b_stats.items():
            lbl = 'jail="' + quote(jail) + '"'
            lines.append(metric_line("stealth_vps_fail2ban_currently_banned", lbl, s["currently_banned"]))
            lines.append(metric_line("stealth_vps_fail2ban_total_banned", lbl, s["total_banned"]))
            lines.append(metric_line("stealth_vps_fail2ban_currently_failed", lbl, s["currently_failed"]))
            lines.append(metric_line("stealth_vps_fail2ban_total_failed", lbl, s["total_failed"]))

    return lines


def write_atomic(path, content):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=os.path.dirname(path), prefix=".tmp-")
    try:
        os.write(fd, content.encode())
        os.close(fd)
        os.chmod(tmp, 0o644)
        os.rename(tmp, path)
    except Exception:
        try:
            os.unlink(tmp)
        except OSError:
            pass
        raise


def main():
    panel_inbounds, panel_err = fetch_panel_inbounds()
    (hy_traffic, hy_online), hy_err = fetch_hysteria_traffic()
    cert_seconds, cert_err = fetch_cert_expiry()
    f2b_stats, f2b_err = fetch_fail2ban_stats()
    if panel_err:
        print("# panel: " + panel_err, file=sys.stderr)
    if hy_err:
        print("# hysteria: " + hy_err, file=sys.stderr)
    if cert_err:
        print("# cert: " + cert_err, file=sys.stderr)
    if f2b_err:
        print("# fail2ban: " + f2b_err, file=sys.stderr)
    lines = build_lines(
        panel_inbounds, panel_err,
        hy_traffic, hy_online, hy_err,
        cert_seconds, cert_err,
        f2b_stats, f2b_err,
    )
    write_atomic(OUTPUT_FILE, "\n".join(lines) + "\n")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except Exception:
        traceback.print_exc(file=sys.stderr)
        sys.exit(1)
