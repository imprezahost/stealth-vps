# /etc/stealth-vps/bot.env — systemd EnvironmentFile for stealth-vps-bot.
#
# Rendered by tasks/bot.yml every Ansible run. Contains the bot token,
# admin chat IDs, and a snapshot of the URI parameters the bot needs to
# build per-user subscription links. Mode 0640 (root:stealth-vps-bot).
#
# Do not edit by hand — re-rendered on every `s-vps update`. Override via
# Ansible vars in inventory or the install.sh prompts.

# --- Bot identity --------------------------------------------------------
STEALTH_VPS_BOT_TOKEN={{ stealth_vps_bot_token }}
# Comma-separated initial admin chat IDs. Leave empty to enter pairing
# mode on first boot — the first chat that sends /start becomes admin.
STEALTH_VPS_BOT_ADMIN_CHAT_IDS={{ stealth_vps_bot_admin_chat_ids | join(',') }}

# --- Paths ---------------------------------------------------------------
STEALTH_VPS_BOT_STATE_FILE=/var/lib/stealth-vps-bot/state.json
STEALTH_VPS_BOT_USERS_INDEX={{ stealth_vps_users_index_path }}
STEALTH_VPS_BOT_CREDENTIALS_FILE={{ stealth_vps_credentials_file }}
STEALTH_VPS_BOT_SUBSCRIPTIONS_DIR=/var/lib/stealth-vps/subscriptions
# Headless-mode paths the bot's _make_backend dispatcher reads. The
# panel state file's PRESENCE flips the bot between ThreeXUIBackend
# (panel mode) and HeadlessBackend (panel mode disabled). The reloader-
# args.json is written by tasks/headless_reload.yml in headless mode
# and absent in panel mode (in which case the bot won't try to
# construct a Reloader anyway).
STEALTH_VPS_BOT_PANEL_STATE_PATH={{ stealth_vps_panel_state_dir }}/panel.state.yml
STEALTH_VPS_BOT_RELOADER_ARGS_PATH={{ stealth_vps_panel_state_dir }}/reloader-args.json

# --- Feature flags -------------------------------------------------------
STEALTH_VPS_BOT_PANEL_ENABLED={{ stealth_vps_panel_enabled | bool | ternary('true', 'false') }}
STEALTH_VPS_BOT_HYSTERIA_ENABLED={{ stealth_vps_hysteria_enabled | bool | ternary('true', 'false') }}
STEALTH_VPS_BOT_SUBSCRIPTION_ENABLED={{ stealth_vps_subscription_enabled | bool | ternary('true', 'false') }}
# In headless mode the bot calls Reloader → systemctl restart. Bot
# user isn't root, so we ask the reloader to prefix with `sudo -n`.
# tasks/bot.yml drops the matching /etc/sudoers.d/ rule that grants
# NOPASSWD for exactly those two systemctl restart commands.
STEALTH_VPS_BOT_USE_SUDO={{ (not (stealth_vps_panel_enabled | bool)) | ternary('true', 'false') }}

# --- 3X-UI panel (read by the bot for /user add via ThreeXUIBackend) ----
{% if stealth_vps_panel_enabled %}
{# panel scheme is detected by tasks/panel.yml (HTTPS preferred, HTTP fallback) #}
{% set _scheme = stealth_vps_panel_scheme | default('http') %}
STEALTH_VPS_BOT_PANEL_URL={{ _scheme }}://127.0.0.1:{{ stealth_vps_panel_state.port }}/{{ stealth_vps_panel_state.web_base_path }}/
STEALTH_VPS_BOT_PANEL_USERNAME={{ stealth_vps_panel_state.username }}
STEALTH_VPS_BOT_PANEL_PASSWORD={{ stealth_vps_panel_state.password }}
{% else %}
STEALTH_VPS_BOT_PANEL_URL=
STEALTH_VPS_BOT_PANEL_USERNAME=
STEALTH_VPS_BOT_PANEL_PASSWORD=
{% endif %}

# --- Reality URI parameters ---------------------------------------------
# `host` is what clients dial. When a domain is configured we hand out
# the domain so SNI + cert match. Otherwise it's the public IPv4.
{% set public_host = stealth_vps_domain if stealth_vps_domain else (ansible_facts.default_ipv4.address | default(ansible_facts.fqdn)) %}
STEALTH_VPS_BOT_PUBLIC_HOST={{ public_host }}
STEALTH_VPS_BOT_REALITY_PORT={{ stealth_vps_reality_state.port }}
STEALTH_VPS_BOT_REALITY_SNI={{ stealth_vps_reality_servernames | first }}
STEALTH_VPS_BOT_REALITY_PUBLIC_KEY={{ stealth_vps_reality_state.public_key }}
STEALTH_VPS_BOT_REALITY_SHORT_ID={{ stealth_vps_reality_state.short_id }}
STEALTH_VPS_BOT_REALITY_FINGERPRINT={{ stealth_vps_reality_fingerprint }}
STEALTH_VPS_BOT_REALITY_FLOW={{ stealth_vps_reality_flow }}
STEALTH_VPS_BOT_REALITY_REMARK={{ stealth_vps_reality_remark }}

# --- Hysteria2 URI parameters -------------------------------------------
{% if stealth_vps_hysteria_enabled %}
{% set hy_sni = stealth_vps_domain if stealth_vps_domain else stealth_vps_hysteria_cert_cn %}
STEALTH_VPS_BOT_HYSTERIA_PORT={{ stealth_vps_hysteria_state.port }}
STEALTH_VPS_BOT_HYSTERIA_SNI={{ hy_sni }}
STEALTH_VPS_BOT_HYSTERIA_OBFS_TYPE=salamander
STEALTH_VPS_BOT_HYSTERIA_OBFS_PASSWORD={{ stealth_vps_hysteria_state.obfs_password }}
STEALTH_VPS_BOT_HYSTERIA_REMARK={{ stealth_vps_hysteria_remark }}
STEALTH_VPS_BOT_HYSTERIA_INSECURE={{ 'false' if stealth_vps_domain else 'true' }}
{% if stealth_vps_hysteria_port_hopping %}
STEALTH_VPS_BOT_HYSTERIA_PORT_HOP_MIN={{ stealth_vps_hysteria_port_hopping_min }}
STEALTH_VPS_BOT_HYSTERIA_PORT_HOP_MAX={{ stealth_vps_hysteria_port_hopping_max }}
{% else %}
STEALTH_VPS_BOT_HYSTERIA_PORT_HOP_MIN=
STEALTH_VPS_BOT_HYSTERIA_PORT_HOP_MAX=
{% endif %}
{% endif %}

# --- Subscription endpoint -----------------------------------------------
# Public URL prefix the bot includes in `/sub` responses.
{% if stealth_vps_subscription_enabled %}
{% if stealth_vps_subscription_expose %}
{% if stealth_vps_domain %}
STEALTH_VPS_BOT_SUBSCRIPTION_PUBLIC_URL=https://{{ stealth_vps_domain }}{{ stealth_vps_subscription_path }}
{% else %}
STEALTH_VPS_BOT_SUBSCRIPTION_PUBLIC_URL=https://{{ public_host }}{{ stealth_vps_subscription_path }}
{% endif %}
{% else %}
# Loopback-only: clients fetch via SSH tunnel.
STEALTH_VPS_BOT_SUBSCRIPTION_PUBLIC_URL=http://127.0.0.1:8443{{ stealth_vps_subscription_path }}
{% endif %}
{% else %}
STEALTH_VPS_BOT_SUBSCRIPTION_PUBLIC_URL=
{% endif %}
