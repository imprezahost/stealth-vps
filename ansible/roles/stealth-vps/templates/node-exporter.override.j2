# {{ ansible_managed }}
# Override the upstream prometheus-node-exporter unit so it binds to
# the address stealth-vps configured (default 127.0.0.1:9100, i.e.
# loopback-only — operators tunnel from a central Prometheus) and
# picks up the stealth-vps-specific .prom files written by the
# metrics updater.

[Service]
# Wipe whatever the package shipped and replace.
ExecStart=
ExecStart=/usr/bin/prometheus-node-exporter \
  --web.listen-address={{ stealth_vps_observability_listen }} \
{% if stealth_vps_metrics_enabled %}
  --collector.textfile.directory={{ stealth_vps_metrics_textfile_dir }}
{% endif %}
