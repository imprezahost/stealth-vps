# {{ ansible_managed }}
# Override the upstream prometheus-node-exporter unit so it binds to
# the address stealth-vps configured (default 127.0.0.1:9100, i.e.
# loopback-only — operators tunnel from a central Prometheus).

[Service]
# Wipe whatever the package shipped and replace.
ExecStart=
ExecStart=/usr/bin/prometheus-node-exporter --web.listen-address={{ stealth_vps_observability_listen }}
