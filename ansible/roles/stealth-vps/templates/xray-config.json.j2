{#- Xray-core config.json for the stealth-vps standalone Reality inbound.

   Rendered by tasks/reality_xray_standalone.yml on first install. In
   headless mode (panel_enabled=false) tasks/headless_reload.yml then
   re-renders this same file from users.index.json via
   stealth_vps.reloader. The two renders MUST produce byte-identical
   output for the multi-converge idempotence test in molecule to pass —
   otherwise every ansible run flip-flops the file:

     converge 1: ansible writes single-client format
                 reloader writes its format (different bytes → CHANGED)
     converge 2: ansible writes single-client format (different bytes again → CHANGED)
                 reloader writes its format again
     → idempotence test fails with `changed=2` on every run.

   To dodge the trap, we build the config as a Jinja dict literal and
   dump it via `to_nice_json(sort_keys=true, indent=2)`. The reloader
   uses `json.dumps(..., sort_keys=True, indent=2)`. Same input → same
   output, byte-for-byte. ansible-lint flags multi-line jinja dicts
   (jinja[spacing]); disabled per-template.

   Schema (Xray-core ≥1.8): https://xtls.github.io/config/
-#}
{%- set _client = {
  "id": stealth_vps_reality_state.client_uuid,
  "email": (stealth_vps_reality_state.client_email
            | default(stealth_vps_reality_default_client_email)),
  "flow": stealth_vps_reality_flow,
} -%}
{%- set _config = {
  "log": {"loglevel": "warning"},
  "inbounds": [
    {
      "tag": "reality-in",
      "listen": "0.0.0.0",
      "port": stealth_vps_reality_state.port,
      "protocol": "vless",
      "settings": {
        "clients": [_client],
        "decryption": "none",
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "xver": 0,
          "dest": stealth_vps_reality_dest,
          "serverNames": stealth_vps_reality_servernames,
          "privateKey": stealth_vps_reality_state.private_key,
          "shortIds": [stealth_vps_reality_state.short_id],
        },
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"],
        "metadataOnly": false,
        "routeOnly": false,
      },
    }
  ],
  "outbounds": [
    {"protocol": "freedom", "tag": "direct"},
    {"protocol": "blackhole", "tag": "blocked"},
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {"type": "field", "ip": ["geoip:private"], "outboundTag": "blocked"},
    ],
  },
} -%}
{# noqa: jinja[spacing] #}
{{ _config | to_nice_json(sort_keys=true, indent=2) }}
