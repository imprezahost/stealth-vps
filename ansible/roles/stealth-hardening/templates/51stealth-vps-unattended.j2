// {{ ansible_managed }}
// stealth-vps — override the upstream /etc/apt/apt.conf.d/50unattended-upgrades
// defaults. Loaded after the upstream file because of the 51- prefix.

// Apply ONLY security updates by default. Non-security upgrades stay
// manual so a routine patch never reboots into a regression at 03:00.
Unattended-Upgrade::Origins-Pattern {
    "origin=Debian,codename=${distro_codename},label=Debian-Security";
    "origin=Debian,codename=${distro_codename}-security,label=Debian-Security";
};

// Clean apt cache after upgrades.
Unattended-Upgrade::AutoFixInterruptedDpkg "true";
Unattended-Upgrade::MinimalSteps "true";
Unattended-Upgrade::InstallOnShutdown "false";
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";
Unattended-Upgrade::Remove-New-Unused-Dependencies "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";

// Do not auto-reboot. Operator decides after a security patch lands —
// kernel upgrades on a stealth proxy with active sessions warrant a
// human pulling the trigger.
Unattended-Upgrade::Automatic-Reboot "false";

// Mail nothing by default. Override via inventory if you want digest
// emails to a configured MTA.
Unattended-Upgrade::Mail "";
Unattended-Upgrade::MailReport "on-change";

// Run with verbose logging for the first weeks; flip to "false" once
// the loop is trusted.
Unattended-Upgrade::Verbose "true";

// Skip packages we never want auto-touched (e.g. ones we pin manually
// in this repo via Ansible). Add to the inventory list to extend.
Unattended-Upgrade::Package-Blacklist {
{% for pkg in stealth_hardening_unattended_blacklist | default([]) %}
    "{{ pkg }}";
{% endfor %}
};
